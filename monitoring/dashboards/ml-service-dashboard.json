{
  "dashboard": {
    "id": null,
    "title": "FraudGuard 360 - ML Service Dashboard",
    "tags": ["fraudguard", "ml", "fraud-detection"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"]
    },
    "panels": [
      {
        "id": 1,
        "title": "ML Service Health Overview",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"fraudguard-ml-service\"}",
            "legendFormat": "Service Status"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            },
            "mappings": [
              {"options": {"0": {"text": "DOWN"}}, "type": "value"},
              {"options": {"1": {"text": "UP"}}, "type": "value"}
            ]
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Prediction Request Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(ml_predictions_total[5m])",
            "legendFormat": "Predictions/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "reqps"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Model Accuracy",
        "type": "stat",
        "targets": [
          {
            "expr": "ml_model_accuracy",
            "legendFormat": "Accuracy"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.8},
                {"color": "green", "value": 0.9}
              ]
            },
            "unit": "percentunit",
            "min": 0,
            "max": 1
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Fraud Detection Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(ml_fraud_predictions_total{prediction=\"fraud\"}[5m]) / rate(ml_predictions_total[5m])",
            "legendFormat": "Fraud Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.1},
                {"color": "red", "value": 0.3}
              ]
            },
            "unit": "percentunit"
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Prediction Latency",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, ml_prediction_duration_seconds_bucket)",
            "legendFormat": "50th percentile"
          },
          {
            "expr": "histogram_quantile(0.95, ml_prediction_duration_seconds_bucket)",
            "legendFormat": "95th percentile"
          },
          {
            "expr": "histogram_quantile(0.99, ml_prediction_duration_seconds_bucket)",
            "legendFormat": "99th percentile"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "s"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 6,
        "title": "Model Performance Metrics",
        "type": "timeseries",
        "targets": [
          {
            "expr": "ml_model_precision",
            "legendFormat": "Precision"
          },
          {
            "expr": "ml_model_recall",
            "legendFormat": "Recall"
          },
          {
            "expr": "ml_model_f1_score",
            "legendFormat": "F1 Score"
          },
          {
            "expr": "ml_model_accuracy",
            "legendFormat": "Accuracy"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "percentunit",
            "min": 0,
            "max": 1
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 7,
        "title": "Fraud Predictions by Type",
        "type": "piechart",
        "targets": [
          {
            "expr": "increase(ml_fraud_predictions_by_type_total[1h])",
            "legendFormat": "{{fraud_type}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"}
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16}
      },
      {
        "id": 8,
        "title": "Risk Score Distribution",
        "type": "histogram",
        "targets": [
          {
            "expr": "ml_risk_score_bucket",
            "legendFormat": "Risk Score"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "continuous-GrYlRd"}
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16}
      },
      {
        "id": 9,
        "title": "Model Ensemble Weights",
        "type": "timeseries",
        "targets": [
          {
            "expr": "ml_ensemble_model_weight",
            "legendFormat": "{{model_name}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "percentunit"
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16}
      },
      {
        "id": 10,
        "title": "System Resource Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "ml_service_cpu_usage_percent",
            "legendFormat": "CPU Usage"
          },
          {
            "expr": "ml_service_memory_usage_percent",
            "legendFormat": "Memory Usage"
          },
          {
            "expr": "ml_service_gpu_usage_percent",
            "legendFormat": "GPU Usage"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24}
      },
      {
        "id": 11,
        "title": "Error Rates",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(ml_prediction_errors_total[5m])",
            "legendFormat": "Prediction Errors"
          },
          {
            "expr": "rate(ml_model_loading_errors_total[5m])",
            "legendFormat": "Model Loading Errors"
          },
          {
            "expr": "rate(ml_feature_extraction_errors_total[5m])",
            "legendFormat": "Feature Errors"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "ops"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24}
      },
      {
        "id": 12,
        "title": "Data Quality Metrics",
        "type": "timeseries",
        "targets": [
          {
            "expr": "ml_missing_features_rate",
            "legendFormat": "Missing Features Rate"
          },
          {
            "expr": "ml_anomalous_features_rate",
            "legendFormat": "Anomalous Features Rate"
          },
          {
            "expr": "ml_data_drift_score",
            "legendFormat": "Data Drift Score"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "percentunit"
          }
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 32}
      },
      {
        "id": 13,
        "title": "Active Fraud Alerts by Severity",
        "type": "bargauge",
        "targets": [
          {
            "expr": "ml_active_alerts_by_severity",
            "legendFormat": "{{severity}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 50}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40}
      },
      {
        "id": 14,
        "title": "Model Inference Queue",
        "type": "timeseries",
        "targets": [
          {
            "expr": "ml_inference_queue_size",
            "legendFormat": "Queue Size"
          },
          {
            "expr": "ml_inference_queue_processing_rate",
            "legendFormat": "Processing Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"}
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40}
      }
    ]
  }
}