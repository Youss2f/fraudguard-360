{
  "dashboard": {
    "id": null,
    "title": "FraudGuard 360 - Business Intelligence",
    "tags": ["fraudguard", "business", "kpi"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "1m",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Daily Transaction Volume",
        "type": "stat",
        "targets": [
          {
            "expr": "fraudguard_daily_transaction_volume",
            "legendFormat": "Transactions Today"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 0,
          "y": 0
        }
      },
      {
        "id": 2,
        "title": "Fraud Detection Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(fraudguard_fraud_detections_total[24h]) * 100",
            "legendFormat": "Detection Rate %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 1
                },
                {
                  "color": "green",
                  "value": 2
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 6,
          "y": 0
        }
      },
      {
        "id": 3,
        "title": "Total Savings (24h)",
        "type": "stat",
        "targets": [
          {
            "expr": "increase(fraudguard_fraud_loss_prevented_amount[24h])",
            "legendFormat": "Amount Saved"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 12,
          "y": 0
        }
      },
      {
        "id": 4,
        "title": "System Uptime",
        "type": "stat",
        "targets": [
          {
            "expr": "up{job=\"fraudguard-api-gateway\"}",
            "legendFormat": "API Gateway"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "options": {
                  "0": {
                    "text": "Down",
                    "color": "red"
                  },
                  "1": {
                    "text": "Up",
                    "color": "green"
                  }
                }
              }
            ]
          }
        },
        "gridPos": {
          "h": 8,
          "w": 6,
          "x": 18,
          "y": 0
        }
      },
      {
        "id": 5,
        "title": "Fraud Cases by Hour",
        "type": "graph",
        "targets": [
          {
            "expr": "increase(fraudguard_fraud_detections_total[1h])",
            "legendFormat": "{{severity}} - {{detection_type}}"
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 0,
          "y": 8
        }
      },
      {
        "id": 6,
        "title": "Financial Impact Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "increase(fraudguard_fraud_prevention_savings_total[1h])",
            "legendFormat": "Savings per Hour"
          },
          {
            "expr": "increase(fraudguard_potential_fraud_amount_total[1h])",
            "legendFormat": "Potential Loss Prevented"
          }
        ],
        "yAxes": [
          {
            "label": "USD"
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 12,
          "y": 8
        }
      },
      {
        "id": 7,
        "title": "Alert Response Times",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(fraudguard_fraud_detection_latency_seconds_bucket[5m]))",
            "legendFormat": "95th percentile"
          },
          {
            "expr": "histogram_quantile(0.50, rate(fraudguard_fraud_detection_latency_seconds_bucket[5m]))",
            "legendFormat": "Median"
          }
        ],
        "yAxes": [
          {
            "label": "Seconds"
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 0,
          "y": 17
        }
      },
      {
        "id": 8,
        "title": "Top Fraud Patterns",
        "type": "table",
        "targets": [
          {
            "expr": "topk(10, increase(fraudguard_suspicious_patterns_detected_total[24h]))",
            "legendFormat": "{{pattern_type}}"
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 12,
          "x": 12,
          "y": 17
        }
      },
      {
        "id": 9,
        "title": "Model Performance Trend",
        "type": "graph",
        "targets": [
          {
            "expr": "fraudguard_model_accuracy_score",
            "legendFormat": "Accuracy"
          },
          {
            "expr": "fraudguard_false_positive_rate * 100",
            "legendFormat": "False Positive Rate %"
          }
        ],
        "yAxes": [
          {
            "label": "Percentage"
          }
        ],
        "gridPos": {
          "h": 9,
          "w": 24,
          "x": 0,
          "y": 26
        }
      }
    ]
  }
}