# FraudGuard 360° Environment Configuration
# Copy this file to .env and update with your actual values

# =====================================
# APPLICATION CONFIGURATION
# =====================================

# Application Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
APP_VERSION=2.0.0

# =====================================
# DATABASE CONFIGURATION
# =====================================

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fraudguard360
POSTGRES_USER=fraudguard_user
POSTGRES_PASSWORD=fraudguard_password_change_me
POSTGRES_URL=postgresql://fraudguard_user:fraudguard_password_change_me@localhost:5432/fraudguard360

# Neo4j Configuration
NEO4J_HOST=localhost
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fraudguard360_change_me
NEO4J_URI=bolt://localhost:7687

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_me
REDIS_URL=redis://:redis_password_change_me@localhost:6379

# =====================================
# MESSAGE QUEUE CONFIGURATION
# =====================================

# Apache Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=fraud-transactions
KAFKA_TOPIC_ALERTS=fraud-alerts
KAFKA_TOPIC_CDR=cdr-events
KAFKA_CONSUMER_GROUP=fraudguard-consumers
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# =====================================
# AUTHENTICATION & SECURITY
# =====================================

# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API Security
API_RATE_LIMIT_PER_MINUTE=1000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
API_CORS_CREDENTIALS=true

# Encryption Keys
ENCRYPTION_KEY=your_encryption_key_32_chars_long
HASH_SALT=your_hash_salt_here

# =====================================
# MACHINE LEARNING CONFIGURATION
# =====================================

# Model Configuration
ML_MODEL_PATH=/app/models/fraud_detection_model.pkl
ML_MODEL_VERSION=1.0.0
ML_PREDICTION_THRESHOLD=0.75
ML_BATCH_SIZE=32
ML_MAX_WORKERS=4

# GraphSAGE Model Settings
GRAPHSAGE_HIDDEN_DIMS=64,32
GRAPHSAGE_NUM_LAYERS=2
GRAPHSAGE_DROPOUT=0.1
GRAPHSAGE_LEARNING_RATE=0.01

# =====================================
# SERVICE CONFIGURATION
# =====================================

# API Gateway
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
API_GATEWAY_WORKERS=4

# AI Service
AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8001
AI_SERVICE_WORKERS=2

# Graph Service
GRAPH_SERVICE_HOST=0.0.0.0
GRAPH_SERVICE_PORT=8002
GRAPH_SERVICE_WORKERS=2

# Processing Service (Flink)
FLINK_JOBMANAGER_HOST=localhost
FLINK_JOBMANAGER_PORT=8081
FLINK_TASKMANAGER_SLOTS=4
FLINK_PARALLELISM=4

# Alerting Service
ALERTING_SERVICE_HOST=0.0.0.0
ALERTING_SERVICE_PORT=8003
ALERTING_SERVICE_WORKERS=2

# =====================================
# MONITORING & OBSERVABILITY
# =====================================

# Prometheus Configuration
PROMETHEUS_HOST=localhost
PROMETHEUS_PORT=9090
METRICS_ENABLED=true
METRICS_PATH=/metrics

# Grafana Configuration
GRAFANA_HOST=localhost
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_change_me

# Logging Configuration
LOG_FORMAT=json
LOG_FILE_PATH=/var/log/fraudguard360/app.log
LOG_MAX_FILE_SIZE=100MB
LOG_BACKUP_COUNT=5

# =====================================
# EXTERNAL SERVICES
# =====================================

# Email Service (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@fraudguard360.com
SMTP_PASSWORD=smtp_password_change_me
SMTP_TLS=true

# Slack Integration (for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#fraud-alerts

# External API Configuration
EXTERNAL_API_TIMEOUT=30
EXTERNAL_API_RETRIES=3

# =====================================
# DEVELOPMENT CONFIGURATION
# =====================================

# Development Tools
HOT_RELOAD=true
AUTO_MIGRATION=true
SEED_DATA=true

# Testing Configuration
TEST_DATABASE_URL=postgresql://test_user:test_pass@localhost:5432/fraudguard_test
TEST_REDIS_URL=redis://localhost:6379/1
TEST_NEO4J_URI=bolt://localhost:7687

# =====================================
# PRODUCTION OVERRIDES
# =====================================
# Uncomment and modify these for production deployment

# ENVIRONMENT=production
# DEBUG=false
# LOG_LEVEL=WARNING
# HOT_RELOAD=false
# AUTO_MIGRATION=false
# SEED_DATA=false

# Production Database URLs (use secrets management)
# POSTGRES_URL=postgresql://prod_user:secure_password@db.example.com:5432/fraudguard_prod
# REDIS_URL=redis://:secure_password@redis.example.com:6379
# NEO4J_URI=bolt://neo4j.example.com:7687

# Production Kafka (use TLS)
# KAFKA_BOOTSTRAP_SERVERS=kafka1.example.com:9093,kafka2.example.com:9093
# KAFKA_SECURITY_PROTOCOL=SSL
# KAFKA_SSL_CAFILE=/path/to/ca-cert.pem
# KAFKA_SSL_CERTFILE=/path/to/client-cert.pem
# KAFKA_SSL_KEYFILE=/path/to/client-key.pem

# Production Security
# JWT_SECRET_KEY=very_secure_production_jwt_secret
# ENCRYPTION_KEY=32_character_production_encryption_key
# API_CORS_ORIGINS=https://your-production-domain.com

# =====================================
# DOCKER CONFIGURATION
# =====================================

# Docker Compose Services
COMPOSE_PROJECT_NAME=fraudguard360
COMPOSE_FILE=docker-compose.yml

# Container Configuration
CONTAINER_TIMEZONE=UTC
CONTAINER_USER=fraudguard
CONTAINER_UID=1000
CONTAINER_GID=1000

# =====================================
# KUBERNETES CONFIGURATION
# =====================================

# Kubernetes Namespace
K8S_NAMESPACE=fraudguard-360
K8S_CLUSTER_NAME=fraudguard-cluster

# Ingress Configuration
INGRESS_CLASS=nginx
INGRESS_DOMAIN=fraudguard360.com
INGRESS_TLS_SECRET=fraudguard-tls

# =====================================
# PERFORMANCE TUNING
# =====================================

# Connection Pools
DB_POOL_SIZE=20
DB_POOL_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30

# Cache Configuration
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000

# Processing Limits
MAX_BATCH_SIZE=1000
PROCESSING_TIMEOUT_SECONDS=30
MAX_CONCURRENT_REQUESTS=100

# =====================================
# FEATURE FLAGS
# =====================================

# Enable/Disable Features
FEATURE_BATCH_PROCESSING=true
FEATURE_REAL_TIME_ALERTS=true
FEATURE_GRAPH_ANALYTICS=true
FEATURE_ML_INFERENCE=true
FEATURE_AUDIT_LOGGING=true
FEATURE_RATE_LIMITING=true

# =====================================
# BACKUP & RECOVERY
# =====================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=fraudguard-backups
BACKUP_S3_REGION=us-east-1

# =====================================
# COMPLIANCE & AUDIT
# =====================================

# Audit Configuration
AUDIT_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years
PII_ANONYMIZATION=true
DATA_RETENTION_DAYS=2555

# Compliance Flags
GDPR_COMPLIANCE=true
PCI_DSS_COMPLIANCE=true
SOX_COMPLIANCE=true