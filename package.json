{
  "name": "fraudguard-360",
  "version": "1.0.0",
  "description": "Advanced fraud detection system with real-time monitoring and ML-powered risk assessment",
  "main": "index.js",
  "scripts": {
    "start": "node api-gateway/app/server.js",
    "dev": "nodemon api-gateway/app/server.js",
    "build": "echo 'Building FraudGuard 360 application...'",
    "build:frontend": "if [ -d 'frontend' ]; then cd frontend && npm run build; else echo 'Frontend directory not found'; fi",
    "build:services": "echo 'Building microservices...' && npm run build:ml && npm run build:risk",
    "build:ml": "cd ml-service && python -m py_compile *.py",
    "build:risk": "cd risk-scoring-service && python -m py_compile *.py",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest --testPathPattern=unit --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:fix": "npm run lint -- --fix",
    "type-check": "tsc --noEmit",
    "security": "npm audit && npm run security:snyk",
    "security:snyk": "snyk test",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "clean": "rm -rf node_modules frontend/node_modules coverage dist build",
    "health-check": "node scripts/health-check.js",
    "migrate": "echo 'Running database migrations...'",
    "seed": "echo 'Seeding database...'",
    "docs": "jsdoc -c jsdoc.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install"
  },
  "keywords": [
    "fraud-detection",
    "machine-learning",
    "risk-assessment",
    "real-time-monitoring",
    "fintech",
    "security"
  ],
  "author": "Youssef",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/youss2f/fraudguard-360.git"
  },
  "bugs": {
    "url": "https://github.com/youss2f/fraudguard-360/issues"
  },
  "homepage": "https://github.com/youss2f/fraudguard-360#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.8.1",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.1",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "mongoose": "^7.4.1",
    "morgan": "^1.10.0",
    "redis": "^4.6.7",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.3",
    "@types/node": "^20.4.2",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "audit-ci": "^7.1.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^28.9.0",
    "eslint-plugin-security": "^3.0.1",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.4",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.2.4",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3",
    "snyk": "^1.1293.0",
    "supertest": "^7.0.0",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "**/*.{js,jsx,ts,tsx}",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/dist/**",
      "!**/build/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
